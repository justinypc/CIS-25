#include <iostream>
#include <string>
using namespace std;

struct Patient
{
    int id;
    string name;
    int age;
};

int main()
{
    Patient patient1;
    patient1.id = 101;
    patient1.name = "Linus";
    patient1.age = 56;
    Patient* p = &patient1;
    cout << "Patient Info" << endl;
    cout << "ID: " << p->id << endl;
    cout << "Name: " << p->name << endl;
    cout << "Age: " << p->age << endl;
    return 0;
}


